# ============================================
# Job Outreach Automation — Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------- MongoDB -------
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=job_outreach

# ------- AI Provider -------
# Options: claude | grok | ollama
AI_PROVIDER=claude

# Claude (used if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Grok (used if AI_PROVIDER=grok)
GROK_API_KEY=your_grok_api_key
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3

# Ollama (used if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ------- Gmail -------
GMAIL_ADDRESS=you@gmail.com
GMAIL_CREDENTIALS_PATH=backend/secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=backend/secrets/gmail_token.json

# ------- LinkedIn Scraper -------
LINKEDIN_SEARCH_KEYWORDS=full stack developer
LINKEDIN_SEARCH_LOCATION=Bangalore
LINKEDIN_COOKIES_PATH=backend/session/linkedin_cookies.json

# ------- Your Profile (used by AI email writer) -------
MY_NAME=Your Full Name
MY_ROLE=Full Stack Developer
MY_SKILLS=React, Node.js, Python, PostgreSQL, AWS
MY_EXPERIENCE_YEARS=3
MY_LINKEDIN_URL=https://linkedin.com/in/yourprofile
MY_GITHUB_URL=https://github.com/yourusername
MY_PORTFOLIO_URL=https://yourportfolio.com

# ------- Automation -------
DAILY_SEND_LIMIT=20
SCRAPE_SCHEDULE_HOUR=8
